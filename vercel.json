{
  "version": 2,
  "builds": [
    { "src": "api/ai.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "yaya/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ai", "dest": "/api/ai.js" },
    { "src": "/yaya/?$", "dest": "/yaya/index.html" },
    { "src": "/yaya/(servizi|chi-siamo|contatti)/?$", "dest": "/yaya/$1.html" },
    { "src": "/yaya/(.*)", "dest": "/yaya/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
