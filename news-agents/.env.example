# ─── API Anthropic (Claude) ───────────────────────────────────────────────────
# Ottieni la tua chiave su: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email Zoho ───────────────────────────────────────────────────────────────
# Usa l'indirizzo email Zoho e la relativa password
# Se usi un dominio custom (es. @creativemessadv.it) su Zoho, metti quello
EMAIL_USER=roberto@creativemessadv.it
EMAIL_PASSWORD=la-tua-password-zoho

# Destinatario delle email (di default uguale a EMAIL_USER)
EMAIL_RECIPIENT=roberto@creativemessadv.it
